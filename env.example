# Copy this file to .env and fill in your key. NEVER commit .env.
# Get the key from LeafLink: Settings > Applications > Create an App (READ access to Orders).
LEAFLINK_API_KEY=""

# --- Optional overrides (defaults are usually fine) ---
# App tokens use the V2 API at www.leaflink.com/api/v2/ (sandbox: sandbox.leaflink.com)
# LEAFLINK_API_BASE="https://www.leaflink.com"
# LEAFLINK_ENDPOINT="/api/v2/orders-received/"
# LEAFLINK_INCLUDE_CHILDREN="line_items"
# LEAFLINK_PAGE_SIZE="500"
